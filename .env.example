# Copy to .env for live mode (never commit real secrets)
# DRY_RUN=true keeps all channels logged-only

DRY_RUN=true

# Models
XAI_API_KEY=
OPENROUTER_API_KEY=
OUTREACH_PRIMARY_MODEL=grok-4
OUTREACH_FALLBACK_PROVIDER=openrouter
OUTREACH_FALLBACK_MODEL=anthropic/claude-sonnet-4

# Email (live later)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI voice
BLAND_API_KEY=
VAPI_API_KEY=

# Handoff notify (Discord primary)
DISCORD_HANDOFF_WEBHOOK_URL=
DISCORD_HANDOFF_CHANNEL_ID=
# DISCORD_BOT_TOKEN=  # optional if using bot+channel instead of webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_HANDOFF_CHAT_ID=
HANDOFF_WEBHOOK_URL=
